<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Chat</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Segoe UI', sans-serif;
      background: #111b21;
      color: #e9edef;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }

    /* Card */
    .card {
      background: #202c33;
      border-radius: 12px;
      width: 100%;
      max-width: 420px;
      overflow: hidden;
    }

    /* Header */
    .header {
      background: #202c33;
      padding: 14px 16px;
      display: flex;
      align-items: center;
      gap: 12px;
      border-bottom: 1px solid #2a3942;
    }
    .back-btn {
      background: transparent;
      border: none;
      color: #00a884;
      font-size: 20px;
      cursor: pointer;
      padding: 0;
      line-height: 1;
      text-decoration: none;
    }
    .header-text h2 { font-size: 16px; font-weight: 600; color: #e9edef; }
    .header-text p  { font-size: 12px; color: #8696a0; }

    /* Avatar */
    .avatar {
      width: 38px; height: 38px;
      border-radius: 50%;
      background: #2a3942;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      font-weight: 600;
      color: #00a884;
      text-transform: uppercase;
      flex-shrink: 0;
    }

    /* Info pills */
    .info-bar {
      padding: 12px 16px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      border-bottom: 1px solid #2a3942;
    }
    .info-row {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
    }
    .info-label { color: #8696a0; width: 44px; flex-shrink: 0; }
    .info-value { color: #e9edef; }

    /* Body */
    .body { padding: 1rem; display: flex; flex-direction: column; gap: 12px; }

    .field label {
      display: block;
      font-size: 11px;
      color: #00a884;
      margin-bottom: 6px;
      letter-spacing: 0.04em;
    }

    /* Message box */
    .msg-area {
      background: #111b21;
      border-radius: 10px;
      padding: 10px 12px;
      position: relative;
    }
    .msg-area textarea {
      width: 100%;
      background: transparent;
      border: none;
      color: #e9edef;
      font-size: 14px;
      font-family: inherit;
      resize: none;
      outline: none;
      min-height: 110px;
      line-height: 1.6;
    }
    .msg-area textarea::placeholder { color: #8696a0; }
    .emoji { position: absolute; right: 10px; bottom: 10px; font-size: 18px; cursor: pointer; }

    /* Footer */
    .footer {
      padding: 0.8rem 1rem 1rem;
      display: flex;
      gap: 10px;
      border-top: 1px solid #2a3942;
    }
    .cancel-btn {
      flex: 1;
      padding: 10px;
      background: transparent;
      border: 1px solid #2a3942;
      color: #8696a0;
      font-size: 14px;
      font-weight: 600;
      border-radius: 8px;
      cursor: pointer;
      font-family: inherit;
      text-align: center;
      text-decoration: none;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.15s;
    }
    .cancel-btn:hover { background: #2a3942; }
    .save-btn {
      flex: 2;
      padding: 10px;
      background: #00a884;
      border: none;
      color: #111b21;
      font-size: 14px;
      font-weight: 700;
      border-radius: 8px;
      cursor: pointer;
      font-family: inherit;
      transition: background 0.15s;
    }
    .save-btn:hover { background: #00c49a; }
  </style>
</head>
<body>

  <div class="card">

    <!-- Header -->
    <div class="header">
      <a href="/chats" class="back-btn">&#8592;</a>
      <div class="avatar"><%= chat.to.charAt(0) %></div>
      <div class="header-text">
        <h2>Edit message</h2>
        <p>Update your message below</p>
      </div>
    </div>

    <!-- From / To info -->
    <div class="info-bar">
      <div class="info-row">
        <span class="info-label">From</span>
        <span class="info-value"><%= chat.from %></span>
      </div>
      <div class="info-row">
        <span class="info-label">To</span>
        <span class="info-value"><%= chat.to %></span>
      </div>
    </div>

    <!-- Edit form -->
    <form action="/chats/<%= chat._id %>?_method=PUT" method="POST">
      <div class="body">
        <div class="field">
          <label>MESSAGE</label>
          <div class="msg-area">
            <textarea name="msg" required><%= chat.msg %></textarea>
            <span class="emoji">😊</span>
          </div>
        </div>
      </div>

      <div class="footer">
        <a href="/chats" class="cancel-btn">Cancel</a>
        <button type="submit" class="save-btn">Save changes</button>
      </div>
    </form>

  </div>

</body>
</html>