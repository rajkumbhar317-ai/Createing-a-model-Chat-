<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>All Chats</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Segoe UI', sans-serif;
      background: #111b21;
      color: #e9edef;
      min-height: 100vh;
    }
    .top-bar {
      background: #202c33;
      padding: 14px 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid #2a3942;
      position: sticky; top: 0; z-index: 10;
    }
    .top-bar h1 { font-size: 20px; font-weight: 600; }
    .new-btn {
      background: #00a884;
      border: none;
      color: #111b21;
      font-size: 13px;
      font-weight: 600;
      padding: 7px 14px;
      border-radius: 20px;
      cursor: pointer;
      font-family: inherit;
    }
    .new-btn:hover { background: #00c49a; }
    .section-label { padding: 8px 16px; font-size: 12px; color: #8696a0; }
    .chat-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      border-bottom: 1px solid #1e2b33;
      transition: background 0.15s;
    }
    .chat-item:hover { background: #2a3942; }
    .avatar {
      width: 46px; height: 46px;
      border-radius: 50%;
      background: #2a3942;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      font-weight: 600;
      color: #00a884;
      flex-shrink: 0;
      text-transform: uppercase;
    }
    .chat-info { flex: 1; min-width: 0; }
    .chat-top {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 3px;
    }
    .chat-name { font-size: 15px; font-weight: 500; }
    .chat-time { font-size: 11px; color: #8696a0; }
    .chat-preview {
      font-size: 13px;
      color: #8696a0;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .chat-preview span { color: #aaa; }

    /* Edit button */
    .edit-btn {
      background: transparent;
      border: 1px solid #2a3942;
      color: #00a884;
      font-size: 12px;
      font-weight: 600;
      padding: 5px 12px;
      border-radius: 16px;
      cursor: pointer;
      font-family: inherit;
      flex-shrink: 0;
      transition: background 0.15s, border-color 0.15s;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }
    .edit-btn:hover {
      background: #00a88420;
      border-color: #00a884;
    }
  </style>
</head>
<body>

  <div class="top-bar">
    <h1>Chats</h1>
    <form action="/chats/new" method="GET">
      <button class="new-btn" type="submit">+ New chat</button>
    </form>
  </div>

  <div class="section-label">Recent</div>

  <% for(let chat of chats) { %>
    <div class="chat-item">
      <div class="avatar"><%= chat.to.charAt(0) %></div>
      <div class="chat-info">
        <div class="chat-top">
          <span class="chat-name"><%= chat.to %></span>
          <span class="chat-time"><%= chat.created_at.toString().split(" ")[4] %></span>
        </div>
        <div class="chat-preview">
          <span>From <%= chat.from %> · </span><%= chat.msg %>
        </div>
      </div>

      <!-- Edit button -->
      <a href="/chats/<%= chat._id %>/edit" class="edit-btn">✏️ Edit</a>

    </div>
  <% } %>

</body>
</html>

